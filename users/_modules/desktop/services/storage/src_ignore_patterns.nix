[
  # Curated from ~/src/**/.gitignore.
  # Keep this limited to generated artifacts and local cache directories.
  # .git syncing is intentional; it is intentionally omitted from ignore patterns.
  # Deliberately do not exclude env/config files such as .env, .npmrc, or .python-version.
  ".DS_Store"
  "__pycache__"
  "*.py[oc]"
  ".pytest_cache"
  ".ruff_cache"
  ".mypy_cache"
  ".venv"
  "venv"
  "node_modules"
  "dist"
  "build"
  "coverage"
  "tmp"
  ".next"
  "out"
  "target"
]
