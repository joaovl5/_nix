[
  # Curated from ~/src/**/.gitignore.
  # Keep this limited to generated artifacts and local cache directories.
  # Deliberately do not exclude env/config files such as .env, .npmrc, or .python-version.
  ".DS_Store"
  "__pycache__/"
  "*.py[oc]"
  ".pytest_cache/"
  ".ruff_cache/"
  ".mypy_cache/"
  ".venv/"
  "venv/"
  "node_modules/"
  "dist/"
  "build/"
  "coverage/"
  "tmp/"
  ".next/"
  "out/"
  "target/"
]
